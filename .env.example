# ===== TELEGRAM =====
TELEGRAM_TOKEN=your_bot_token_here

# ===== HH API =====
HH_CLIENT_ID=your_hh_client_id
HH_CLIENT_SECRET=your_hh_client_secret

# Токен приложения HH — ОБЯЗАТЕЛЕН для поиска вакансий (/vacancies).
# Без него HH API возвращает 403 Forbidden.
#
# Как получить:
#   python scripts/get_hh_app_token.py
#
# Под капотом скрипт делает:
#   POST https://api.hh.ru/token
#   grant_type=client_credentials&client_id=...&client_secret=...
#
# Полученный access_token вставьте сюда:
HH_ACCESS_TOKEN=your_hh_app_access_token

# ===== OPENAI =====
OPENAI_API_KEY=sk-...
# Профиль кандидата — fallback если resume.md не найден
USER_PROFILE=Python backend разработчик (FastAPI, Telegram-боты, AI automation).
# Путь к Markdown-файлу с резюме (основной контекст для генерации писем)
RESUME_MD_PATH=profile/resume.md

# ===== GOOGLE SHEETS =====
GOOGLE_SHEET_ID=your_spreadsheet_id
GOOGLE_SHEET_NAME=CRM
GOOGLE_CREDENTIALS_PATH=credentials.json

# ===== APP =====
DEBUG=true
LOG_LEVEL=INFO
