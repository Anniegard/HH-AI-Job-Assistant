# ===== TELEGRAM =====
TELEGRAM_TOKEN=your_bot_token_here

# ===== HH API =====
HH_CLIENT_ID=your_hh_client_id
HH_CLIENT_SECRET=your_hh_client_secret
# HH_ACCESS_TOKEN=  # заполняется после OAuth, если нужно

# ===== OPENAI =====
OPENAI_API_KEY=sk-...
# Профиль кандидата — используется в промпте для генерации письма
USER_PROFILE=Python backend разработчик (FastAPI, Telegram-боты, AI automation).

# ===== GOOGLE SHEETS =====
GOOGLE_SHEET_ID=your_spreadsheet_id
GOOGLE_SHEET_NAME=CRM
GOOGLE_CREDENTIALS_PATH=credentials.json

# ===== APP =====
DEBUG=true
LOG_LEVEL=INFO
